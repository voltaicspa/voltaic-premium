# ===== VARIABLES DE ENTORNO =====
# Copia este archivo a .env.local y rellena tus valores

# 🔑 GROQ API (para server.js local)
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_API_KEY=your_groq_api_key_here

# 🔐 VERCEL / PRODUCCIÓN
# Para Vercel, agrega estas variables en:
# Vercel Dashboard → Settings → Environment Variables

# 📍 DOMINIO PERMITIDO (en producción, puede ser múltiple)
ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# 🤖 reCAPTCHA v3
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
RECAPTCHA_THRESHOLD=0.5

# 📊 Google Sheets Webhook (si usas Apps Script)
GOOGLE_SHEETS_URL=https://script.google.com/macros/d/YOUR_SCRIPT_ID/usercontent

# 🌐 ENTORNO
NODE_ENV=development
PORT=3000

# ===== INSTRUCCIONES PARA VERCEL =====
# 1. Crea un proyecto en vercel.com
# 2. Ve a Settings → Environment Variables
# 3. Agrega cada variable de arriba (excepto PORT, que Vercel maneja)
# 4. La API estará en: https://tu-proyecto.vercel.app/api/chat
